# SECRETS LIVE IN ~/.hermes/.env (single source of truth, shared with the
# Hermes gateway/dashboard): TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID,
# DEEPSEEK_API_KEY / GLM_API_KEY. `swing_trader serve` loads that file first;
# a local trader/.env is OPTIONAL (non-secret overrides only) and values
# already present in the environment take precedence over it.
# NEVER commit real secrets anywhere (Loop.md §3). Env names match §3 verbatim.

# --- Safety / mode ---
DRY_RUN=true            # default true; nothing leaves the machine while true
BROKER=paper            # paper | alpaca | ibkr
HUMAN_CONFIRM=false     # live orders need HUMAN_CONFIRM=true AND BROKER!=paper AND DRY_RUN=false

# --- Risk (hard caps in swing_trader/constants.py; looser values are rejected) ---
PER_TRADE_RISK_PCT=1.0          # hard cap 1.6
DAILY_DRAWDOWN_BREAKER_PCT=-4.0 # hard cap -4.0

# --- Daily window (ET) ---
PUSH_TIME_ET=11:30
CONFIRM_CUTOFF_ET=12:30

# --- Storage / logging ---
DB_PATH=trader.db
LOG_LEVEL=INFO
LOG_FORMAT=json         # json | console

# --- Secrets ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
